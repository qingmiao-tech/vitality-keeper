{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vitality-keeper",
  "version": "0.1.7",
  "identifier": "com.kingmo.vitality-keeper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "元气守恒·筑基令",
        "width": 1024,
        "height": 720,
        "decorations": false,
        "transparent": true,
        "url": "dashboard.html",
        "center": true,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "sidebarImage": "icons/installer-sidebar.bmp",
        "installerHooks": "windows/nsis-hooks.nsh"
      },
      "wix": {
        "version": "0.1.7.0"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/qingmiao-tech/vitality-keeper/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxNDY3REM0RUQwRkJCN0EKUldSNnV3L3R4SDFHTWZpL0ZieUpKYTQ4ZllsbGo5N3ZMb0NjaXhOYS9LaDk5VlVSNnVCb29pVWYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
