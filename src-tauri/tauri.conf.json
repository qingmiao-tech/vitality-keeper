{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vitality-keeper",
  "version": "0.1.6",
  "identifier": "com.kingmo.vitality-keeper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "元气守恒·筑基令",
        "width": 1024,
        "height": 720,
        "decorations": false,
        "transparent": true,
        "url": "dashboard.html",
        "center": true,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "sidebarImage": "icons/installer-sidebar.bmp",
        "installerHooks": "windows/nsis-hooks.nsh"
      },
      "wix": {
        "version": "0.1.6.0"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
